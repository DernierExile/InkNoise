# =============================================================================
# InkNoise · Environment variables
# Copy this file to `.env` and fill in the values.
# =============================================================================

# --- Supabase (already configured in your Bolt project) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe Price IDs (client-side, exposed in bundle) ---
# Create three Stripe products in your Stripe Dashboard, then paste their
# Price IDs here. Use TEST mode price IDs first (price_test_xxx).
VITE_STRIPE_PRICE_STUDIO_MONTHLY=price_xxx_studio_monthly
VITE_STRIPE_PRICE_STUDIO_ANNUAL=price_xxx_studio_annual
VITE_STRIPE_PRICE_FOUNDER_LIFETIME=price_xxx_founder_lifetime

# =============================================================================
# Edge Functions secrets (DO NOT put these in this file or any client env)
# Set them via: Supabase Dashboard → Edge Functions → Secrets
# Or via CLI: supabase secrets set KEY=value
#
# Required:
#   STRIPE_SECRET_KEY=sk_test_xxx
#   STRIPE_WEBHOOK_SECRET=whsec_xxx
#   STRIPE_PRICE_ID_STUDIO_MONTHLY=price_xxx
#   STRIPE_PRICE_ID_STUDIO_ANNUAL=price_xxx
#   STRIPE_PRICE_ID_FOUNDER_LIFETIME=price_xxx
#
# Auto-set by Supabase (no need to set manually):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
# =============================================================================
